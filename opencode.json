{
  "$schema": "./opencode.schema.json",
  "model": "ollama/qwen2.5-coder:7b",
  "disabled_providers": ["google"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "Qwen2.5 Coder 7B",
          "tool_call": true,
          "limit": { "context": 32768, "output": 8192 }
        },
        "phi3:mini": {
          "name": "Phi-3 Mini",
          "limit": { "context": 131072, "output": 8192 }
        },
        "qwen2:latest": {
          "name": "Qwen2",
          "limit": { "context": 32768, "output": 8192 }
        }
      }
    }
  },
  "mcp": {
    "notebooklm": {
      "type": "local",
      "command": [
        "node",
        "--no-warnings",
        "C:\\Users\\flier\\.gemini\\antigravity\\scratch\\notebooklm-mcp\\dist\\index.js"
      ]
    },
    "reverse-geocoding-api": {
      "type": "local",
      "command": [
        "node",
        "--no-warnings",
        "c:\\Users\\flier\\.gemini\\antigravity\\scratch\\Reverse-Geocoding\\mcp-server\\index.js"
      ]
    }
  },
  "command": {
    "master-prompt": {
      "template": "Actúa como un Ingeniero de Prompts especializado en sistemas GIS y Reverse-Geocoding avanzado. Tu objetivo es utilizar exclusivamente la documentación técnica de NotebookLM y las fuentes para generar prompts maestros que optimicen las llamadas a la API.",
      "description": "Utiliza la técnica Autoprompter 2000 desde NotebookLM."
    },
    "master-sync": {
      "template": "node ../notebooklm-mcp/sync-requested-notebook.mjs",
      "description": "Sincroniza el estado actual leyendo y aplicando el script de NotebookLM"
    }
  }
}